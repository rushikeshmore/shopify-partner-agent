# Shopify Partner API credentials
# From: Partners Dashboard > Settings > Partner API clients
# Permissions needed: "Manage apps" + "View financials"

# Your organization ID (from URL: partners.shopify.com/{org_id})
SHOPIFY_ORG_ID=

# Partner API client access token
SHOPIFY_ACCESS_TOKEN=

# Comma-separated app GIDs (from Partners Dashboard > Apps > click app > ID in URL)
# Prefix with gid://partners/App/
# Example: gid://partners/App/1234567,gid://partners/App/7654321
SHOPIFY_APP_IDS=

# API version (optional, defaults to 2026-01)
SHOPIFY_API_VERSION=2026-01
